# ======================================
# 性能优化配置
# ======================================

# 数据库性能配置
# PERF_DB_MAX_OPEN_CONNS=16              # 最大打开连接数 (默认: CPU核心数*2)
# PERF_DB_MAX_IDLE_CONNS=8               # 最大空闲连接数 (默认: CPU核心数)
# PERF_DB_CONN_MAX_LIFETIME_MINUTES=60   # 连接最大生命周期(分钟)
# PERF_DB_CONN_MAX_IDLE_TIME_MINUTES=10  # 连接最大空闲时间(分钟)
# PERF_DB_SLOW_QUERY_MS=100              # 慢查询阈值(毫秒)
# PERF_DB_ENABLE_QUERY_LOG=false         # 是否启用查询日志
# PERF_DB_ENABLE_EXPLAIN=false           # 是否启用EXPLAIN
# PERF_DB_DEFAULT_BATCH_SIZE=100         # 默认批处理大小
# PERF_DB_MAX_BATCH_SIZE=1000            # 最大批处理大小

# 缓存性能配置
# PERF_CACHE_LOCAL_ENABLED=true          # 是否启用本地缓存
# PERF_CACHE_LOCAL_SIZE=10000            # 本地缓存大小
# PERF_CACHE_LOCAL_TTL_SECONDS=300       # 本地缓存TTL(秒)
# PERF_CACHE_REDIS_ENABLED=true          # 是否启用Redis缓存
# PERF_CACHE_REDIS_PIPELINE_SIZE=100     # Redis Pipeline批量大小
# PERF_CACHE_REDIS_POOL_SIZE=10          # Redis连接池大小
# PERF_CACHE_ENABLE_WARMUP=false         # 是否启用缓存预热
# PERF_CACHE_ENABLE_LOCK=true            # 是否启用缓存锁(防止缓存击穿)

# 并发性能配置
# PERF_WORKER_POOL_SIZE=32               # 工作池大小 (默认: CPU核心数*4)
# PERF_WORKER_QUEUE_SIZE=1000            # 工作队列大小
# PERF_WORKER_IDLE_TIMEOUT_SECONDS=60    # 工作器空闲超时(秒)
# PERF_MAX_CONCURRENT_REQUESTS=1000      # 最大并发请求数
# PERF_MAX_CONCURRENT_QUERIES=100        # 最大并发查询数

# 监控配置
# PERF_METRICS_ENABLED=true              # 是否启用性能指标收集
# PERF_METRICS_INTERVAL_SECONDS=60       # 指标收集间隔(秒)
# PERF_METRICS_RETENTION_HOURS=24        # 指标保留时间(小时)
# PERF_SLOW_QUERY_ENABLED=true           # 是否启用慢查询日志
# PERF_SLOW_QUERY_LIMIT=100              # 慢查询保留数量
# PERF_PPROF_ENABLED=false               # 是否启用pprof性能分析
# PERF_PPROF_PORT=6060                   # pprof端口

# ======================================
# 安全说明
# ======================================
# 1. 请修改所有密码和密钥
# 2. 生产环境请使用环境变量或密钥管理服务
# 3. 不要将此文件提交到版本控制
# 4. 定期轮换密码和密钥
# ======================================